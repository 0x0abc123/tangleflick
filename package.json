{
  "name": "tangleflick",
  "version": "0.1.0",
  "description": "A Bun + TypeScript template framework: config-driven event bus (Kafka / NATS / embedded) and shared data store (Postgres / SQLite) behind stable ports & adapters.",
  "type": "module",
  "module": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "migrate": "bun run src/cli/migrate.ts",
    "seed": "bun run scripts/seed.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "kafkajs": "^2.2.4",
    "nats": "^2.29.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.2"
  }
}

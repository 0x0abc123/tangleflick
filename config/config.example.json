{
  "app": {
    "name": "tangleflick",
    "logLevel": "info"
  },
  "bus": {
    "type": "emitter"
  },
  "store": {
    "type": "sqlite",
    "path": "./data/tangleflick.db"
  },
  "http": {
    "enabled": false,
    "host": "0.0.0.0",
    "port": 3000,
    "path": "/webhook",
    "allowedEvents": ["example.created"],
    "auth": {
      "type": "apiKey",
      "header": "authorization",
      "scheme": "Bearer",
      "token": "env:WEBHOOK_TOKEN"
    }
  }
}
